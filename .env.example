QWEN_API_KEY=sk-your-dashscope-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Embeddings may need a different compatible-mode endpoint than chat completions.
QWEN_EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_COMPILER_MODEL=qwen-plus
QWEN_AGENT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_ENABLE_EXPLICIT_CACHE=true

MONGODB_URI=mongodb://localhost:27017/companybrain_nexaflow?replicaSet=rs0&directConnection=true
MONGODB_DB_NAME=companybrain_nexaflow

# Leave PUBLIC_BASE_URL empty for local development. `deploy/issue-certificate.sh`
# writes the verified HTTPS hostname only after Certbot succeeds.
PUBLIC_BASE_URL=
MCP_SERVER_URL=http://localhost:8000/mcp/
MCP_TRANSPORT=streamable-http
MCP_REMOTE_ENABLED=false
MCP_REQUIRE_API_KEY=true
MCP_LEGACY_SSE_ENABLED=false
# Comma-separated browser origins allowed to initiate an authenticated MCP call.
MCP_ALLOWED_ORIGINS=
# Comma-separated CORS origins for the REST/UI deployment. Keep empty locally;
# the TLS issuance script writes https://brain.veriflowai.me after verification.
CORS_ALLOWED_ORIGINS=

HOST=0.0.0.0
PORT=8000

INITIAL_CONFIDENCE=0.60
CONFIDENCE_INTERCEPT=0.70
CONFIDENCE_AUTO_EXECUTE=0.85
CONFIDENCE_INCREMENT=0.05
EMBEDDING_DIMENSIONS=1024

BRAIN_API_KEY=change-me-before-deploy
# NexaFlow's public console is a read-only view of this one local demo org.
# No browser request can submit source data or choose another organization.
DEMO_ORG_ID=nexaflow-demo
SOURCE_ORG_ID=nexaflow-demo
DEMO_SCENARIO_VERSION=nexaflow-live-v1
# Set by deploy/deploy.sh. Leave unknown for local development.
BUILD_SHA=unknown

# TDX (Alibaba Confidential VM g7t/g8i). On r9i / non-TDX hosts, RSA audit is used.
TDX_BINARY_PATH=/opt/alibaba/tdx-quote-generation-sample/app
TDX_TIMEOUT=10
AUDIT_PRIVATE_KEY_PATH=secrets/audit_private.pem
AUDIT_PUBLIC_KEY_PATH=secrets/audit_public.pem

# Optional real GitHub PR → skill compiler webhook
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_REPOS=owner/repository

# Source-backed Reality Memory. Values below are deliberately empty: keep
# provider credentials on the server only, never in the browser or repository.
# For a local rehearsal, `scripts/start-local.ps1` generates these values
# without printing them. Production must provide its own secret values.
INTEGRATION_ADMIN_TOKEN=
INTEGRATION_CONFIG_ENCRYPTION_KEY=
LOCAL_REHEARSAL=false

# Slack Events API (read-only #ops-incidents intake)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_ALLOWED_TEAM_ID=
SLACK_ALLOWED_CHANNEL_IDS=
SLACK_EVENT_MAX_AGE_SECONDS=300

# Alibaba Cloud OSS (private, read-only runbook prefix)
ALIBABA_OSS_REGION=cn-hongkong
ALIBABA_OSS_ENDPOINT=https://oss-cn-hongkong.aliyuncs.com
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_PREFIX=runbooks/
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_ALLOWED_EXTENSIONS=md,txt,pdf
ALIBABA_OSS_SYNC_INTERVAL_SECONDS=300
ALIBABA_OSS_MAX_FILE_BYTES=750000

# Verified Web evidence (no web search; exact public HTTPS host allowlist)
WEB_EVIDENCE_ALLOWED_HOSTS=
WEB_EVIDENCE_MAX_BYTES=250000
WEB_EVIDENCE_TIMEOUT_SECONDS=8
SOURCE_WORKER_POLL_SECONDS=2

# Alias accepted by some deploy docs
DASHSCOPE_API_KEY=
MONGODB_URL=
